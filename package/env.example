APP_NAME=aurora-kvm-agent
APP_NODE_ID=01K00000000000000000000000
SHUTDOWN_TIMEOUT_SEC=15

GRPC_BIND_ADDR=0.0.0.0:8081

AGENT_BOOTSTRAP_TARGET_ADDR=hypervisor.auroracloud.local:9443
AGENT_RUNTIME_TARGET_ADDR=http://dataplane-zone-default-1.auroracloud.local:50051
AGENT_RUNTIME_TARGET_ADDRS=http://dataplane-zone-default-1.auroracloud.local:50051,http://dataplane-zone-default-2.auroracloud.local:50051
AGENT_SERVER_NAME=
AGENT_CA_PATH=/etc/aurora-kvm-agent/tls/ca.crt
AGENT_CERT_PATH=/etc/aurora-kvm-agent/tls/client.crt
AGENT_KEY_PATH=/etc/aurora-kvm-agent/tls/client.key
AGENT_BOOTSTRAP_TOKEN=bootstrap
AGENT_HEARTBEAT_INTERVAL_SEC=10
AGENT_CONNECT_TIMEOUT_SEC=3
AGENT_FAILOVER_BASE_BACKOFF_MS=200
AGENT_FAILOVER_MAX_BACKOFF_MS=3000
AGENT_VERSION=0.1.0

WORKER_MAX=64
